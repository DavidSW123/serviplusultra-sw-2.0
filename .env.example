# Turso (Base de datos en la nube)
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu_token_aqui

# Google Gemini (Escáner IA de tickets)
GEMINI_API_KEY=tu_api_key_aqui

# Google Apps Script (Relay de email para facturas)
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
